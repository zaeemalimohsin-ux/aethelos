# Copy to .env.docker (or let Start-AethelOS.bat generate it).
# Rebuild the client service after changing LAN IP: docker compose up --build client

VITE_DEFAULT_RELAY_URL=ws://localhost:8787
VITE_INVITE_BASE_URL=http://localhost:8080

# LAN sharing example (replace with your machine's IPv4):
# VITE_DEFAULT_RELAY_URL=ws://192.168.1.42:8787
# VITE_INVITE_BASE_URL=http://192.168.1.42:8080
