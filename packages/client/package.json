{
  "name": "@aethelos/client",
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:federation-off": "playwright test -c playwright.federation-off.config.ts --project=federation-off",
    "test:e2e:federation-on": "playwright test -c playwright.federation-on.config.ts --project=federation-on",
    "test:e2e:pilot-off": "pnpm test:e2e:federation-off",
    "setup:e2e": "playwright install chromium",
    "playground": "node scripts/multi-person-playground.mjs"
  },
  "dependencies": {
    "@aethelos/core": "workspace:*",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.6.1",
    "@scure/bip39": "^1.5.0",
    "@tauri-apps/api": "^2.2.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "10.0.3",
    "fake-indexeddb": "^6.0.0",
    "playwright": "^1.49.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.6",
    "workbox-window": "^7.3.0",
    "ws": "^8.18.0"
  }
}
