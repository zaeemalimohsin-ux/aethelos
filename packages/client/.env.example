# Optional same-origin companion relay (prepended to the bootstrap pool at build time).
# Usually unnecessary when nginx proxies /ws on the same host as the PWA.
# Example: wss://relay.yourdomain.org
VITE_DEFAULT_RELAY_URL=

# Extra bootstrap relay pool for automatic community assignment when no peer mailboxes exist.
# Comma-separated or JSON array.
# Example: wss://relay-a.example.org,wss://relay-b.example.org,wss://relay-c.example.org
VITE_BOOTSTRAP_RELAYS=

# Public client URL for invite links when it differs from where the PWA is served.
# Usually unnecessary with same-origin deploy; Start-AethelOS share link sets origin at runtime.
# Example: https://app.yourdomain.org
VITE_INVITE_BASE_URL=

# Optional: link shown on welcome screen for "Download desktop app" (GitHub Release URL).
# Example: https://github.com/your-org/aethelos/releases/latest
VITE_DOWNLOAD_URL=

# Optional URL for the in-app "Run your own relay" guide (defaults to /relay-guide.html).
# VITE_RELAY_OPERATOR_GUIDE_URL=
