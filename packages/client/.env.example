# Optional same-origin companion relay (prepended to the bootstrap pool at build time).
# Example: wss://relay.yourdomain.org
VITE_DEFAULT_RELAY_URL=

# Independent bootstrap relay pool for automatic community assignment.
# Each new community gets a deterministic subset (2–3 URLs) — not one global default.
# Comma-separated or JSON array. Replace placeholder slots before public launch.
# Example: wss://relay-a.example.org,wss://relay-b.example.org,wss://relay-c.example.org
VITE_BOOTSTRAP_RELAYS=

# Public client URL for invite links (desktop founders sharing with friends abroad).
# Set to your hosted PWA origin before desktop:dev — relay mailboxes in the payload
# are already public, but friends must load the client shell from a reachable URL.
# Example: https://app.yourdomain.org
VITE_INVITE_BASE_URL=

# Optional URL for the in-app "Run your own relay" guide (defaults to /relay-guide.html).
# VITE_RELAY_OPERATOR_GUIDE_URL=
