{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AethelOS",
  "version": "0.2.5",
  "identifier": "org.aethelos.desktop",
  "build": {
    "frontendDist": "../../client/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --filter @aethelos/client dev",
    "beforeBuildCommand": "node ../../scripts/prepare-release-client.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AethelOS",
        "width": 1100,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ws: wss: http: https:; worker-src 'self' blob:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/relay/*",
      "resources/node/win-x64/*",
      "resources/app-server/*",
      "resources/static/**/*",
      "resources/cloudflared/win-x64/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
