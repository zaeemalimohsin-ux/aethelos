{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AethelOS",
  "version": "0.1.1",
  "identifier": "org.aethelos.desktop",
  "build": {
    "frontendDist": "../../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @aethelos/client dev",
    "beforeBuildCommand": "pnpm --filter @aethelos/client build"
  },
  "app": {
    "windows": [
      {
        "title": "AethelOS",
        "width": 1100,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ws: wss: http: https:; worker-src 'self' blob:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/relay/*", "resources/node/win-x64/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://releases.example.org/aethelos/{{target}}/{{current_version}}"
      ],
      "dialog": true
    }
  }
}
