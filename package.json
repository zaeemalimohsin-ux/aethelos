{
  "name": "aethelos",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "AethelOS — substrate of daily community life without external authority",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:eslint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:relay": "pnpm --filter @aethelos/relay dev",
    "dev:client": "pnpm --filter @aethelos/client dev",
    "test:e2e": "pnpm --filter @aethelos/client test:e2e",
    "setup:e2e": "pnpm --filter @aethelos/client setup:e2e",
    "playground": "pnpm --filter @aethelos/client playground",
    "desktop:proof": "node scripts/desktop-proof.mjs",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.1"
  },
  "packageManager": "pnpm@9.15.0"
}
