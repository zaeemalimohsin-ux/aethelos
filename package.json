{
  "name": "aethelos",
  "private": true,
  "type": "module",
  "version": "0.2.6",
  "description": "AethelOS â€” substrate of daily community life without external authority",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:eslint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:relay": "pnpm --filter @aethelos/relay dev",
    "dev:client": "pnpm --filter @aethelos/client dev",
    "test:e2e": "pnpm --filter @aethelos/client test:e2e",
    "test:e2e:federation-off": "pnpm --filter @aethelos/client test:e2e:federation-off",
    "test:e2e:federation-on": "pnpm --filter @aethelos/client test:e2e:federation-on",
    "test:e2e:pilot-off": "pnpm test:e2e:federation-off",
    "setup:e2e": "pnpm --filter @aethelos/client setup:e2e",
    "playground": "pnpm --filter @aethelos/client playground",
    "desktop:proof": "node scripts/desktop-proof.mjs",
    "desktop:gui-walkthrough": "node scripts/desktop-gui-walkthrough.mjs",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-aethelos.ps1",
    "bundle:relay-sidecar": "node scripts/bundle-relay-sidecar.mjs",
    "fetch:node-sidecar": "node scripts/fetch-node-sidecar.mjs",
    "fetch:cloudflared": "node scripts/fetch-cloudflared.mjs",
    "android:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-pwa-smoke.ps1",
    "proof:product": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/proof-product.ps1",
    "release:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-release.ps1",
    "verify:release": "node scripts/verify-release.mjs",
    "charter-a-preflight": "node scripts/charter-a-preflight.mjs",
    "operator:hosting": "node scripts/operator-hosting.mjs",
    "operator:browser": "node scripts/operator-hosting.mjs fly",
    "operator:browser-smoke": "node scripts/operator-browser.mjs smoke",
    "check:user-docs": "node scripts/check-user-docs.mjs",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.1"
  },
  "packageManager": "pnpm@9.15.0"
}
